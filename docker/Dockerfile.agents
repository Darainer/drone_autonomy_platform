FROM python:3.12-slim

# System deps for deploy-worker (docker, ssh, rsync)
# Lightweight — shared by all agent workers
RUN apt-get update && apt-get install -y --no-install-recommends \
    docker.io \
    openssh-client \
    rsync \
    git \
    && rm -rf /var/lib/apt/lists/*

# Python deps
RUN pip install --no-cache-dir \
    temporalio \
    anthropic

WORKDIR /workspace
