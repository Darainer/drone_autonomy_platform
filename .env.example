# drone_autonomy_platform agent system
# Copy to .env and fill in your values

# Required: Anthropic API key for Claude  (this is a placeholder value, replace with your actual API key)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Orin Nano SSH target for deploy-worker
ORIN_HOST=192.168.1.100
ORIN_USER=jetson

# Optional: Display for Gazebo GUI (sim-worker)
DISPLAY=:0
